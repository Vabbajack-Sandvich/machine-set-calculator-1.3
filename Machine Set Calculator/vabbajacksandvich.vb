                                                    End If
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If

        'these are kind of redundant but whatever
        If z13CommaCheck = True Then

            '1 dot at least in the exe line?
            'the 6 dots in the 2 ips

            '7dots total?

            'these trees help keep the if blocks with a lot of code in them to a minimum
